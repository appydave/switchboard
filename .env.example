# Optional: override the machine identifier baked into every Signal envelope.
# Defaults to os.hostname() at runtime if not set.
# MACHINE_NAME=my-machine

# Pino log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# Add transport / interface / storage env vars below as recipes are wired in.
# Examples:
# HTTP_PUSH_URL=https://example.com/ingest
# HTTP_PUSH_TOKEN=xxxxx

# mcp-binding: path to the snapshot file the MCP server reads.
# Defaults to snapshots/sentinel-latest.json (relative to project root).
# SNAPSHOT_PATH=snapshots/sentinel-latest.json
